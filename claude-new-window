#!/bin/bash
# 在 Trae 内部打开新的对话窗口

# 使用 AppleScript 来模拟键盘快捷键打开新窗口
osascript -e 'tell application "System Events" to keystroke "n" using {command down, shift down}' 2>/dev/null || \
osascript -e 'tell application "Trae CN" to activate' -e 'tell application "System Events" to keystroke "n" using command down' 2>/dev/null || \
open -a "Trae CN"